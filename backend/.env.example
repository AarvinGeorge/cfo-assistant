# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.2

# ── Google Gemini Embeddings ──────────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_EMBED_MODEL=models/gemini-embedding-001
GEMINI_EMBED_DIMENSION=3072

# ── Pinecone Vector Store ─────────────────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key-here
# Create this index in the Pinecone console: dimension=3072, metric=cosine, serverless
PINECONE_INDEX_NAME=finsight-index
PINECONE_NAMESPACE=default

# ── Redis (Docker: docker run -d --name redis-finsight -p 6379:6379 redis:alpine) ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Chunking Parameters ───────────────────────────────────────────────────────
SECTION_CHUNK_TOKENS=512
ROW_CHUNK_TOKENS=128
CHUNK_OVERLAP_TOKENS=64

# ── Retrieval ─────────────────────────────────────────────────────────────────
DEFAULT_TOP_K=5
MMR_LAMBDA=0.5
MMR_FETCH_K=20

# ── Output Paths ──────────────────────────────────────────────────────────────
OUTPUT_DIR=data/outputs
TEMP_DIR=data/tmp
UPLOAD_DIR=data/uploads

# ── Additional API Keys (available for future use) ────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
GROQ_API_KEY=your-groq-api-key-here
GROK_API_KEY=your-grok-api-key-here
